# ============================================================
# NSE/BSE Options Trading Bot — Environment Variables
# Copy to .env and fill in your credentials
# NEVER commit .env to version control
# ============================================================

# --- Broker: Zerodha (Kite) ---
ZERODHA_API_KEY=your_api_key
ZERODHA_API_SECRET=your_api_secret
ZERODHA_ACCESS_TOKEN=your_access_token
ZERODHA_USER_ID=your_user_id

# --- Broker: Fyers ---
FYERS_CLIENT_ID=your_client_id
FYERS_SECRET_KEY=your_secret_key
FYERS_ACCESS_TOKEN=your_access_token

# --- Broker: Angel One ---
ANGEL_API_KEY=your_api_key
ANGEL_CLIENT_ID=your_client_id
ANGEL_PASSWORD=your_password
ANGEL_TOTP_KEY=your_totp_secret

# --- Active broker (zerodha | fyers | angel) ---
ACTIVE_BROKER=zerodha

# --- Paper trading (true = simulation, false = live) ---
PAPER_TRADING=true

# --- Database ---
DATABASE_URL=postgresql://trader:trader@localhost:5432/options_bot
REDIS_URL=redis://localhost:6379/0
MONGO_URL=mongodb://localhost:27017/options_research

# --- Notifications ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Logging ---
LOG_LEVEL=INFO
